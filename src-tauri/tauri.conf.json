{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marky",
  "version": "0.1.4",
  "identifier": "com.smartmemory.marky",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marky",
        "width": 1000,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "tabbingIdentifier": "com.smartmemory.marky.doc"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/smartmemory/marky/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxQkNCQ0MwQ0EyNjA5QjQKUldTMENTYkt3THk4MFJ1bUpQNktWVVRGK1dZZi8zQzN6VXBWc2hBcCt1OVpDTUFMQndrczJHS3UK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mdwn", "mkdn"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ]
  }
}
